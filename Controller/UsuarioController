package br.com.ultravexpotech.controller;
import br.com.ultravexpotech.model.Usuario;
import br.com.ultravexpotech.service.UsuarioService;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@CrossOrigin("*") // java conversa com next
public class UsuarioController {

private final UsuarioService usuarioService;


public UsuarioController(UsuarioService usuarioService) {
    this.usuarioService = usuarioService;
}


@PostMapping("/cadastro")
public Usuario cadastrar(@RequestBody Usuario usuario) {
    return usuarioService.cadastrar(usuario);
}

// listagem
@GetMapping("/usuarios")
public List<Usuario> listar() {
    return usuarioService.listar();
}

// login
@PostMapping("/login")
public ResponseEntity<?> login(@RequestBody Usuario usuario) {
    List<Usuario> listaCadastrada = usuarioService.listar();

    // verifica se a senha e o email são iguais aos que estão cadastrados
    for (Usuario a : listaCadastrada) {
        if (a.getEmail().equalsIgnoreCase(usuario.getEmail()) && a.getSenha().equals(usuario.getSenha())) {
            //retorna seu nome que tu cadastrou
            return ResponseEntity.ok(a.getNome());
        }
    }

    // Se não encontrar da erro 401
    return ResponseEntity.status(401).body("E-mail ou senha incorretos");
}
}
