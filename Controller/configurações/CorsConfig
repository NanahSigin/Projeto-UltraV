package br.com.ultravexpotech.controller.Configurações;

//importa os spring
import org.springframework.context.annotation.Configuration;
import org.springframework.web.servlet.config.annotation.CorsRegistry;
import org.springframework.web.servlet.config.annotation.WebMvcConfigurer;

//configuração de beans (é um objeto que o Spring cria e cuida para você <3 igual sua mãe)
//desculpa se vc não tem mãe
@Configuration
public class CorsConfig implements WebMvcConfigurer {

    // o override é tipo um aviso de eu ja fiz então se fiz merda me avisa
    @Override
    public void addCorsMappings(CorsRegistry registry) {
        registry.addMapping("/**") //entra tudo e todos as (urls da api)
                .allowedOrigins("http://localhost:3000")// isso faz rodar junto do next ou seja só roda desse endereço
                .allowedMethods("GET", "POST", "PUT", "DELETE", "OPTIONS");
        //se vier alguém do localhost:3000 querendo fazer GET, POST, PUT, DELETEou OPTIONS, pode deixar passar

    }
}
